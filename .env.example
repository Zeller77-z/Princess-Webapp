# =============================================================================
# Princess's Viral Campaign Studio — Environment Variables
# =============================================================================

# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only)
# Set this in your hosting provider's environment variables dashboard.
# This key is NEVER exposed to the browser.
GEMINI_API_KEY="your_gemini_api_key_here"

# Supabase Configuration (these are public/safe to expose)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
